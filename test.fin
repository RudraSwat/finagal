(inc "lib/operators.fin")

(ffi-load "libmath.so")
(ffi func_name (int32 int32) -> return_type)

(setq fib .(
    (ifel (= (@args 0) 0) (
        ret 0
    ) ())
    (ifel (= (@args 0) 1) (
        ret 1
    ) ())
    (ret (+ (fib (- (@args 0) 1)) (fib (- (@args 0) 2))))
))

(println (fib 20))

(println (runtime_ctx))
